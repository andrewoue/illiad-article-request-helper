{
  "name": "ILLiad Article Request Helper",
  "description": "Captures article metadata to auto-fill ILLiad request forms. Supports selectable library profiles. Clipboard copy allows for generic list creation.",
  "version": "1.0",
  "manifest_version": 3,
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "ILLiad Helper",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "*://*/*",
    "*://pittstate.illiad.oclc.org/*",
    "*://umkc-illiad-oclc-org.proxy.library.umkc.edu/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["output.html", "output.js", "profiles/*.json"],
      "matches": ["<all_urls>"]
    }
  ]
}